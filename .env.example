# =================================================================
# .env.example - 環境変数テンプレート
#
# このファイルをコピーして .env.local を作成し、各値を埋めてください:
#   cp .env.example .env.local
#
# .env.local は .gitignore 済み(リポジトリにコミットしない)
# =================================================================

# Supabase ローカル開発(supabase start 後に `supabase status` で取得)
#
# 本番 / Preview は Vercel の環境変数で参照先 DB を切り替える(Issue #20):
#   - Production スコープ → 本番プロジェクト(lgtm2)の URL / anon / service_role
#   - Preview スコープ    → Preview プロジェクト(lgtmhub-preview)の値(本番の値は入れない)
# 詳細は docs/development-guidelines.md「本番 DB / Preview DB の分離構成」を参照。
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Blob(本番デプロイ時に Vercel ダッシュボードから取得)
BLOB_READ_WRITE_TOKEN=

# GitHub OAuth は Supabase CLI 専用のため supabase/.env で管理します。
# 詳細: supabase/.env.example を参照、または README の「GitHub OAuth セットアップ」節を参照。
